# ════════════════════════════════════════════════════════════════════════════
# GoBot Environment Template
# Copy to .env: cp .env.example .env
#
# The installer (curl … | bash) fills this automatically.
# Free AI and RPC are pre-configured — no keys required to get started.
# Public surfaces:
#   Hub:      https://github.com/solizardking/solana-clawd
#   Runtime:  https://github.com/Solizardking/clawdbot-go
#   Gateway:  https://zk.x402.wtf
#   Terminal: https://cheshireterminal.ai
# ════════════════════════════════════════════════════════════════════════════

# ── Install identity (set by installer) ──────────────────────────────────────
GOBOT_INSTALL_ID=
GOBOT_AGENT_DNA_ID=
GOBOT_INSTALL_RECEIPT=~/.gobot/install.json

# ── Birth skill seed ────────────────────────────────────────────────────────
# Installer/onboard seeds Solizardking/skills and samber/cc-skills-golang.
# Installer/onboard also creates ~/.gobot/workspace/agent-dna.json.
# Set to 1 to skip networked skill seeding during install/launch.
GOBOT_SKIP_SKILL_SEED=0

# ── Source/install mode ─────────────────────────────────────────────────────
# archive keeps curl installs small by honoring .gitattributes export-ignore.
# Use git if you want ~/.gobot/src to be a checkout.
GOBOT_SOURCE_MODE=archive
# GOBOT_REF=main

# ── Web console hardening ────────────────────────────────────────────────────
# The dashboard binds to localhost by default. Use `gobot web --public` only
# behind a trusted network boundary or reverse proxy.
GOBOT_CORS_ORIGINS=
GOBOT_TRUST_PROXY_HEADERS=0
GOBOT_WEB_EXPOSE_SECRETS=0
GOBOT_WEB_READ_TIMEOUT_SECONDS=15
GOBOT_WEB_WRITE_TIMEOUT_SECONDS=300
GOBOT_WEB_IDLE_TIMEOUT_SECONDS=120

# ── Free AI via zkrouter ─────────────────────────────────────────────────────
# Powered by zk.x402.wtf — sovereign AI routing for $GOBOT holders + gobot installs.
# No API key needed for the free tier. Set ZKROUTER_API_KEY if you have a custom key.
ZKROUTER_BASE_URL=https://clawdrouter-zk.fly.dev/v1
ZKROUTER_API_KEY=clawd-free

# ── Solana RPC ───────────────────────────────────────────────────────────────
# SolanaTracker-backed RPC proxy — no key required for gobot installs.
# Override with your own Helius/QuickNode URL for higher rate limits.
SOLANA_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
HELIUS_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public

# ── Optional: your own keys (removes rate limits) ────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# HELIUS_API_KEY=your-helius-api-key
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# BIRDEYE_API_KEY=your-birdeye-key

# ── Agent wallet (generated by installer; required for startup funding/live use)
AGENT_WALLET_PUBLIC_KEY=
AGENT_WALLET_KEYPAIR=~/.gobot/workspace/agent-wallet.json
SOLANA_WALLET_PUBKEY=
SOLANA_WALLET_KEYPAIR=~/.gobot/workspace/agent-wallet.json
# Private keys stay in the local keypair file or server-side gateway secrets.
# WALLET_PRIVATE_KEY=your-base58-encoded-private-key
# WALLET_ADDRESS=your-solana-wallet-address

# ── Startup funding request / receipts ──────────────────────────────────────
GOBOT_TOKEN_MINT=8cHzQHUS2s2h8TzCmfqPKYiM4dSt4roa3n7MyRLApump
GOBOT_STARTUP_SOL_LAMPORTS=69420000
GOBOT_STARTUP_SOL_AMOUNT=0.069420
GOBOT_STARTUP_TOKENS=1000
GOBOT_INSTALL_FUNDING_STATUS=
GOBOT_SOL_FUNDING_SIGNATURE=
GOBOT_FUNDING_SIGNATURE=
# Local treasury funding is opt-in. Never commit real treasury secrets.
# GOBOT_LOCAL_STARTUP_FUNDING=1
# GOBOT_BIRTH_FUNDING_SEND=1
# GOBOT_TREASURY_KEYPAIR=~/.config/solana/id.json
# GOBOT_TREASURY_PRIVATE_KEY=base58-secret-key

# ── Phoenix perpetual futures (https://phoenix.trade) ────────────────────────
# Public Phoenix reads work without a key. Vulcan is the default execution path.
# PHOENIX_API_URL=https://perp-api.phoenix.trade
VULCAN_BIN=vulcan
VULCAN_DEFAULT_MODE=paper
VULCAN_PAPER_BALANCE=10000
# VULCAN_WALLET_NAME=my-wallet                 # required only for live modes
# VULCAN_WALLET_PASSWORD=your-wallet-password  # required for non-interactive live MCP sessions
VULCAN_MAX_STEP_NOTIONAL_USDC=100
VULCAN_MAX_TOTAL_NOTIONAL_USDC=500
VULCAN_MAX_PRICE_DRIFT_BPS=75
VULCAN_MAX_EXPOSURE_RATIO=2
VULCAN_TIMEOUT_SECONDS=30

#───────────────────────────────────────


# ── Channels (optional) ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# DISCORD_BOT_TOKEN=your-discord-token

# ── xAI Grok (optional override) ─────────────────────────────────────────────
# XAI_API_KEY=your-xai-key
# XAI_MODEL=grok-4.3

# ── Supabase memory (optional) ───────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key

# ── GoBot ZK Agent (optional) ───────────────────────────────────────────────
# GOBOT_ZK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
# GOBOT_ZK_PHOTON_URL=https://zk.x402.wtf/api/solana/rpc-public
# GOBOT_ZK_NETWORK=mainnet
# ZK_SHARK_RPC_URL=https://zk.x402.wtf/api/solana/rpc-public
# ZK_SHARK_NETWORK=mainnet

# ── core-ai sidecar (optional MCP/tooling install) ─────────────────────────
# core-ai is TypeScript/Node tooling, so it is installed beside the Go runtime
# instead of being vendored into go.mod or embedded into the gobot binary.
# GOBOT_INSTALL_CORE_AI=1
# GOBOT_CORE_AI_REPO=https://github.com/Solizardking/core-ai
# GOBOT_CORE_AI_REF=clawdbot-stack-integration
# GOBOT_CORE_AI_DIR=~/.gobot/core-ai
# GOBOT_CORE_AI_MCP_CONFIG=~/.gobot/core-ai.mcp.json

# ── Local GoBot catalogs (read-only discovery) ───────────────────────────────
GOBOT_SKILLS_DIR=/Users/8bit/skills/skills
GOBOT_AGENTS_DIR=/Users/8bit/agents/agents/src
GOBOT_ZK_PRIMITIVES_DIR=/Users/8bit/Agentics/gobot-go/zk-primitives
